# Copy to server/.env (or cloudnest/.env and point dotenv from server — we load from process cwd when running from server/)
# Recommended: create server/.env with:

DB_HOST=localhost
DB_PORT=3306
DB_NAME=cloudnest
DB_USER=root
DB_PASSWORD=yourpassword

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

PORT=5000
CLIENT_URL=http://localhost:5173

# Optional email (password reset / invoice send)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=CloudNest <noreply@cloudnest.in>
